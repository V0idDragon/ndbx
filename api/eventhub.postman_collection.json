{
  "info": {
    "name": "EventHub",
    "description": "Коллекция запросов для тестирования API EventHub. Все запросы работают с локальным окружением (make run).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Session",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/session",
          "host": ["{{base_url}}"],
          "path": ["session"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201 || pm.response.code === 200) {",
              "    const cookie = pm.response.headers.get('Set-Cookie');",
              "    if (cookie) {",
              "        const match = cookie.match(/X-Session-Id=([^;]+)/);",
              "        if (match) pm.collectionVariables.set('session_id', match[1]);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"John Doe\",\n  \"username\": \"john\",\n  \"password\": \"secret\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": ["{{base_url}}"],
          "path": ["users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const cookie = pm.response.headers.get('Set-Cookie');",
              "    if (cookie) {",
              "        const match = cookie.match(/X-Session-Id=([^;]+)/);",
              "        if (match) pm.collectionVariables.set('session_id', match[1]);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john\",\n  \"password\": \"secret\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 204) {",
              "    const cookie = pm.response.headers.get('Set-Cookie');",
              "    if (cookie) {",
              "        const match = cookie.match(/X-Session-Id=([^;]+)/);",
              "        if (match) pm.collectionVariables.set('session_id', match[1]);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": ["{{base_url}}"],
          "path": ["auth", "logout"]
        }
      }
    },
    {
      "name": "Create Event",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Concert\",\n  \"description\": \"Rock music\",\n  \"address\": \"Main St, 1\",\n  \"started_at\": \"2026-05-01T19:00:00Z\",\n  \"finished_at\": \"2026-05-01T21:00:00Z\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/events",
          "host": ["{{base_url}}"],
          "path": ["events"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const resp = pm.response.json();",
              "if (resp.id) pm.collectionVariables.set('event_id', resp.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Events (with filters)",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/events?include=reactions,reviews&category=concert&limit=10",
          "host": ["{{base_url}}"],
          "path": ["events"],
          "query": [
            {"key": "include", "value": "reactions,reviews"},
            {"key": "category", "value": "concert"},
            {"key": "limit", "value": "10"}
          ]
        }
      }
    },
    {
      "name": "Get Event by ID",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}"]
        }
      }
    },
    {
      "name": "Patch Event",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category\": \"concert\",\n  \"price\": 500,\n  \"city\": \"Moscow\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}"]
        }
      }
    },
    {
      "name": "Like Event",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}/like",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}", "like"]
        }
      }
    },
    {
      "name": "Dislike Event",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}/dislike",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}", "dislike"]
        }
      }
    },
    {
      "name": "Create Review",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Great event!\",\n  \"rating\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}/reviews",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}", "reviews"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const resp = pm.response.json();",
              "if (resp.id) pm.collectionVariables.set('review_id', resp.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Reviews",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}/reviews?limit=10&offset=0",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}", "reviews"],
          "query": [
            {"key": "limit", "value": "10"},
            {"key": "offset", "value": "0"}
          ]
        }
      }
    },
    {
      "name": "Patch Review",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Updated comment\",\n  \"rating\": 4\n}"
        },
        "url": {
          "raw": "{{base_url}}/events/{{event_id}}/reviews/{{review_id}}",
          "host": ["{{base_url}}"],
          "path": ["events", "{{event_id}}", "reviews", "{{review_id}}"]
        }
      }
    },
    {
      "name": "Recommendations",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Cookie", "value": "X-Session-Id={{session_id}}"}
        ],
        "url": {
          "raw": "{{base_url}}/recommendations",
          "host": ["{{base_url}}"],
          "path": ["recommendations"]
        }
      }
    },
    {
      "name": "Get Users",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users?name=John&limit=10",
          "host": ["{{base_url}}"],
          "path": ["users"],
          "query": [
            {"key": "name", "value": "John"},
            {"key": "limit", "value": "10"}
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const resp = pm.response.json();",
              "if (resp.users && resp.users.length) pm.collectionVariables.set('user_id', resp.users[0].id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get User by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["users", "{{user_id}}"]
        }
      }
    },
    {
      "name": "Get User Events",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/users/{{user_id}}/events?include=reactions,reviews",
          "host": ["{{base_url}}"],
          "path": ["users", "{{user_id}}", "events"],
          "query": [
            {"key": "include", "value": "reactions,reviews"}
          ]
        }
      }
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://localhost:8080"},
    {"key": "session_id", "value": ""},
